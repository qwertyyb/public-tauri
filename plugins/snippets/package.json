{
  "name": "snippets",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "vite build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.8.0",
  "dependencies": {
    "@public/api": "workspace:^",
    "element-plus": "^2.10.4"
  },
  "publicPlugin": {
    "title": "snippets",
    "subtitle": "snippets",
    "icon": "./assets/snippets.png",
    "main": "./dist/index.js",
    "commands": [
      {
        "name": "create-snippet",
        "title": "create snippet",
        "mode": "none",
        "matches": [
          {
            "type": "text",
            "keywords": [
              "create snippet"
            ]
          }
        ]
      },
      {
        "name": "search-snippets",
        "title": "search snippets",
        "mode": "listView",
        "preload": "./dist/search.preload.js",
        "matches": [
          {
            "type": "text",
            "keywords": [
              "search snippets"
            ]
          }
        ]
      }
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/tsconfig": "^0.7.0",
    "rollup-plugin-external-globals": "^0.13.0",
    "vite": "^7.0.6"
  }
}
