{
  "name": "snippets",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publicPlugin": {
    "title": "snippets",
    "subtitle": "snippets",
    "icon": "./assets/snippets.png",
    "html": "./dist/index.html",
    "commands": [
      {
        "name": "create-snippet",
        "title": "create snippet",
        "mode": "view",
        "matches": [
          {
            "type": "text",
            "keywords": [
              "create snippet"
            ]
          }
        ]
      },
      {
        "name": "search-snippets",
        "title": "search snippets",
        "mode": "view",
        "matches": [
          {
            "type": "text",
            "keywords": [
              "search snippets"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@nuxt/ui": "^4.6.1",
    "@public-tauri/api": "workspace:^",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.18"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.0.1",
    "@vue/tsconfig": "^0.7.0",
    "npm-run-all2": "^8.0.4",
    "typescript": "~5.8.0",
    "vite": "^7.0.6",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vue-tsc": "^3.0.4"
  }
}
