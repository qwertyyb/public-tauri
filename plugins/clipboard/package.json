{
  "name": "clipboard",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "module": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "rollup --config ./rollup.config.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "publicPlugin": {
    "title": "剪切板",
    "subtitle": "剪切板历史",
    "icon": "./assets/logo.png",
    "template": "listView",
    "commands": [
      {
        "name": "clipboard",
        "title": "剪切板",
        "matches": [
          {
            "type": "text",
            "keywords": [
              "剪切板",
              "clipboard",
              "cp"
            ]
          },
          {
            "type": "trigger",
            "triggers": [
              "cp"
            ],
            "title": "搜索剪切板“$query”..."
          }
        ],
        "mode": "listView",
        "preload": "./dist/command.preload.js"
      }
    ]
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "catalog:plugin",
    "@rollup/plugin-node-resolve": "catalog:plugin",
    "@rollup/plugin-replace": "catalog:plugin",
    "rollup": "catalog:plugin",
    "rollup-plugin-esbuild": "catalog:plugin"
  },
  "dependencies": {
    "@public/api": "workspace:^"
  }
}
