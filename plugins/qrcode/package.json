{
  "name": "@public-tauri/plugin-qrcode",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsdown"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "publicPlugin": {
    "title": "二维码",
    "subtitle": "生成、解析二维码",
    "icon": "./assets/qrcode.png",
    "main": "./dist/index.js",
    "server": "./dist/server.js",
    "template": "listView",
    "commands": [
      {
        "name": "generate",
        "title": "生成二维码",
        "subtitle": "生成二维码",
        "mode": "none",
        "matches": [
          {
            "type": "text",
            "keywords": [
              "qrcode",
              "生成二维码"
            ]
          },
          {
            "type": "trigger",
            "triggers": [
              "qr"
            ],
            "title": "生成二维码“$query”"
          }
        ],
        "action": {
          "name": "copy-to-clipboard",
          "title": "复制到剪切板"
        }
      },
      {
        "name": "generate-for-current-url",
        "title": "分享当前页面",
        "subtitle": "生成当前页面的分享二维码",
        "mode": "none",
        "matches": [
          {
            "type": "text",
            "keywords": [
              "qrcu"
            ]
          }
        ],
        "action": {
          "name": "copy-to-clipboard",
          "title": "复制到剪切板"
        }
      },
      {
        "name": "detect",
        "title": "解析二维码",
        "subtitle": "解析二维码",
        "mode": "listView",
        "preload": "./dist/detect.command.js",
        "matches": [
          {
            "type": "text",
            "keywords": [
              "detect qrcode",
              "解析二维码"
            ]
          },
          {
            "type": "file",
            "extensions": [
              "png",
              "jpg",
              "jpeg"
            ]
          }
        ]
      }
    ]
  },
  "devDependencies": {
    "@public-tauri/api": "workspace:^",
    "sharp": "^0.34.3",
    "@types/qrcode": "^1.5.5",
    "tsdown": "catalog:plugin",
    "@public-tauri/wechat-qrcode": "workspace:^",
    "qrcode": "^1.4.4"
  }
}
