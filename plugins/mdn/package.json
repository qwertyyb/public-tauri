{
  "name": "mdn",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "rollup --config ./rollup.config.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "publicPlugin": {
    "title": "MDN文档",
    "subtitle": "搜索 MDN 文档",
    "icon": "./assets/mdn.png",
    "template": "listView",
    "commands": [
      {
        "name": "search-mdn",
        "title": "搜索 MDN 文档",
        "subtitle": "搜索 MDN 文档",
        "mode": "listView",
        "matches": [
          {
            "type": "text",
            "keywords": [
              "MDN",
              "docs",
              "mdn docs"
            ]
          },
          {
            "type": "trigger",
            "triggers": [
              "mdn"
            ],
            "title": "搜索 MDN 文档“$query”..."
          }
        ],
        "preload": "./dist/index.js"
      }
    ]
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "catalog:plugin",
    "@rollup/plugin-json": "catalog:plugin",
    "@rollup/plugin-node-resolve": "catalog:plugin",
    "@rollup/plugin-replace": "catalog:plugin",
    "rollup": "catalog:plugin",
    "rollup-plugin-esbuild": "catalog:plugin"
  },
  "dependencies": {
    "@public-tauri/api": "workspace:^"
  }
}
