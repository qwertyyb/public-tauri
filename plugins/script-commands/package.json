{
  "name": "script-commands",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "publicPlugin": {
    "title": "Script Commands",
    "subtitle": "A plugin for executing script commands",
    "description": "create a script command and execute it with one click",
    "icon": "./assets/icon.png",
    "html": "http://localhost:5173",
    "commands": [
      {
        "name": "create-script-command",
        "title": "create script command",
        "mode": "view"
      },
      {
        "name": "search-script-command",
        "title": "search script command",
        "mode": "view"
      }
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache"
  },
  "dependencies": {
    "@public-tauri/api": "workspace:^",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
