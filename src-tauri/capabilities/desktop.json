{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop-capability",
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "deep-link:default",
    "global-shortcut:default",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "core:window:allow-center",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:app:allow-set-dock-visibility",
    "core:app:allow-default-window-icon",
    "global-shortcut:allow-is-registered",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "**/*"
        }
      ]
    },
    "shellx:allow-execute",
    "shellx:allow-kill",
    {
      "identifier": "shellx:allow-spawn",
      "allow": [
        {
          "name": "binaries/node-v24.11.1",
          "args": true,
          "sidecar": true
        }
      ]
    },
    "fs:read-all",
    "fs:write-all",
    "fs:allow-watch",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$HOME/**/*"
        },
        {
          "path": "$RESOURCE/**/*"
        }
      ]
    },
    "clipboard:allow-start-monitor",
    "clipboard:monitor-all",
    "clipboard:read-all",
    "clipboard:write-all",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-load",
    "sql:allow-select",
    "sql:allow-close",
    "autostart:allow-disable",
    "autostart:allow-enable",
    "autostart:allow-is-enabled",
    "double-tap-shortcut:allow-register",
    "double-tap-shortcut:allow-unregister",
    "dialog:default",
    "process:allow-exit",
    "upload:default"
  ]
}