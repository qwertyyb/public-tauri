{
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "macOS": {
      "minimumSystemVersion": "14.6"
    },
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "tauri-macos-spotlight-app",
  "version": "0.2.0",
  "identifier": "com.tauri.spotlight",
  "plugins": {},
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 580,
        "width": 760,
        "resizable": false,
        "decorations": false,
        "center": true,
        "visible": false,
        "devtools": true,
        "transparent": true,
        "backgroundThrottling": "disabled",
        "windowEffects": {
          "radius": 6,
          "effects": ["popover"]
        }
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      },
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost",
      "devCsp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost"
    },
    "macOSPrivateApi": true
  }
}
