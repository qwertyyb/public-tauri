    {
      "name": "magic",
      "icon": "https://img.icons8.com/?size=100&id=ZXnn88azBI7W&format=png&color=000000",
      "version": "1.0.0",
      "author": "",
      "manifest": {
        "name": "magic",
        "title": "魔方平台",
        "subtitle": "魔方平台快捷操作",
        "icon": "https://img.icons8.com/?size=100&id=ZXnn88azBI7W&format=png&color=000000",
        "main": "./dist/index.js",
        "commands": [
          {
            "name": "editor",
            "title": "魔方H5编辑页",
            "subtitle": "打开魔方H5编辑页",
            "mode": "none",
            "matches": [
              { "type": "text", "keywords": ["magic"] },
              { "type": "trigger", "triggers": ["magic", "mact"], "title": "打开魔方H5编辑页\"$query\"" },
              { "type": "regexp", "regexp": "https://.*/magic-act(-beta|-dev)?/([0-9a-zA-Z]+)/", "title": "打开魔方H5编辑页\"${matches[2]}\"" }
            ],
            "actions": [{ "name": "openUrl", "title": "打开页面" }]
          },
          {
            "name": "mod",
            "title": "魔方模块编辑页",
            "subtitle": "打开魔方模块编辑页",
            "mode": "none",
            "matches": [
              { "type": "text", "keywords": ["magic"] },
              { "type": "trigger", "triggers": ["magic", "mmod"], "title": "打开魔方模块编辑页\"$query\"" }
            ]
          }
        ]
      }
    },
