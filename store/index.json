{
  "updateTime": 1776403848359,
  "plugins": [
    {
      "name": "@public-tauri-ext/magic",
      "icon": "https://img.icons8.com/?size=100&id=ZXnn88azBI7W&format=png&color=000000",
      "version": "1.0.0",
      "author": "",
      "manifest": {
        "name": "@public-tauri-ext/magic",
        "icon": "https://img.icons8.com/?size=100&id=ZXnn88azBI7W&format=png&color=000000",
        "title": "魔方平台",
        "subtitle": "魔方平台快捷操作",
        "main": "./dist/index.js",
        "commands": [
          {
            "name": "editor",
            "title": "魔方H5编辑页",
            "subtitle": "打开魔方H5编辑页",
            "mode": "none",
            "matches": [
              {
                "type": "text",
                "keywords": [
                  "magic"
                ]
              },
              {
                "type": "trigger",
                "triggers": [
                  "magic",
                  "mact"
                ],
                "title": "打开魔方H5编辑页“$query”"
              },
              {
                "type": "regexp",
                "regexp": "https://.*/magic-act(-beta|-dev)?/([0-9a-zA-Z]+)/",
                "title": "打开魔方H5编辑页“${matches[2]}”"
              }
            ],
            "actions": [
              {
                "name": "openUrl",
                "title": "打开页面"
              }
            ]
          },
          {
            "name": "mod",
            "title": "魔方模块编辑页",
            "subtitle": "打开魔方模块编辑页",
            "mode": "none",
            "matches": [
              {
                "type": "text",
                "keywords": [
                  "magic"
                ]
              },
              {
                "type": "trigger",
                "triggers": [
                  "magic",
                  "mmod"
                ],
                "title": "打开魔方模块编辑页“$query”"
              }
            ]
          }
        ]
      }
    },
    {
      "name": "@public-tauri-ext/search",
      "icon": "https://img.icons8.com/?size=100&id=63775&format=png&color=000000",
      "version": "1.1.0",
      "author": "",
      "manifest": {
        "name": "@public-tauri-ext/search",
        "icon": "https://img.icons8.com/?size=100&id=63775&format=png&color=000000",
        "title": "网页搜索",
        "subtitle": "触发词 + 关键词，在浏览器中打开搜索结果",
        "description": "输入触发词与空格后的关键词，回车打开对应搜索引擎：g/google/gg→Google，b/bing/必应→必应，bd/baidu/百度→百度。",
        "main": "./dist/index.js",
        "commands": [
          {
            "name": "google",
            "title": "谷歌搜索",
            "subtitle": "在浏览器中打开 Google 搜索结果",
            "mode": "none",
            "matches": [
              {
                "type": "trigger",
                "triggers": ["g", "google", "gg"],
                "title": "谷歌搜索\"$query\"",
                "subtitle": "在浏览器中打开 Google 搜索结果"
              }
            ]
          },
          {
            "name": "bing",
            "title": "必应搜索",
            "subtitle": "在浏览器中打开必应搜索结果",
            "mode": "none",
            "matches": [
              {
                "type": "trigger",
                "triggers": ["b", "bing", "必应"],
                "title": "必应搜索\"$query\"",
                "subtitle": "在浏览器中打开必应搜索结果"
              }
            ]
          },
          {
            "name": "baidu",
            "title": "百度搜索",
            "subtitle": "在浏览器中打开百度搜索结果",
            "mode": "none",
            "matches": [
              {
                "type": "trigger",
                "triggers": ["bd", "baidu", "百度"],
                "title": "百度搜索\"$query\"",
                "subtitle": "在浏览器中打开百度搜索结果"
              }
            ]
          }
        ]
      }
    },
    {
      "name": "@public-tauri-ext/v2ex",
      "icon": "https://github.com/qwertyyb/public-tauri/blob/master/store/plugins/v2ex/assets/v2ex.png?raw=true",
      "version": "1.0.0",
      "author": "",
      "manifest": {
        "name": "@public-tauri-ext/v2ex",
        "icon": "https://github.com/qwertyyb/public-tauri/blob/master/store/plugins/v2ex/assets/v2ex.png?raw=true",
        "title": "v2ex",
        "subtitle": "查看v2ex热贴和新贴",
        "template": "listView",
        "commands": [
          {
            "name": "hot",
            "title": "v2ex热贴",
            "subtitle": "查看v2ex热贴",
            "mode": "listView",
            "preload": "./dist/command-hot.js"
          },
          {
            "name": "latest",
            "title": "v2ex新贴",
            "subtitle": "查看v2ex新贴",
            "mode": "listView",
            "preload": "./dist/command-latest.js"
          }
        ]
      }
    }
  ]
}