    {
      "name": "qrcode",
      "icon": "https://github.com/qwertyyb/public-tauri/blob/v2/plugins/qrcode/assets/qrcode.png?raw=true",
      "version": "1.0.0",
      "author": "",
      "manifest": {
        "name": "qrcode",
        "title": "二维码",
        "subtitle": "生成、解析二维码",
        "icon": "https://github.com/qwertyyb/public-tauri/blob/v2/plugins/qrcode/assets/qrcode.png?raw=true",
        "main": "./dist/index.js",
        "server": "./dist/server.js",
        "template": "listView",
        "commands": [
          {
            "name": "generate",
            "title": "生成二维码",
            "subtitle": "生成二维码",
            "mode": "none",
            "matches": [
              { "type": "text", "keywords": ["qrcode", "生成二维码"] },
              { "type": "trigger", "triggers": ["qr"], "title": "生成二维码\"$query\"" }
            ],
            "actions": [{ "name": "copy-to-clipboard", "title": "复制到剪切板" }]
          },
          {
            "name": "generate-for-current-url",
            "title": "分享当前页面",
            "subtitle": "生成当前页面的分享二维码",
            "mode": "none",
            "matches": [
              { "type": "text", "keywords": ["qrcu"] }
            ],
            "actions": [{ "name": "copy-to-clipboard", "title": "复制到剪切板" }]
          },
          {
            "name": "detect",
            "title": "解析二维码",
            "subtitle": "解析二维码",
            "mode": "listView",
            "preload": "./dist/detect.command.js",
            "matches": [
              { "type": "text", "keywords": ["detect qrcode", "解析二维码"] },
              { "type": "file", "extensions": ["png", "jpg", "jpeg"] }
            ]
          }
        ]
      }
    },
