{
  "updateTime": 1777615004195,
  "plugins": [
    {
      "name": "@public-tauri-ext/google-chrome",
      "icon": "https://www.google.com/chrome/static/images/chrome-logo.svg",
      "version": "1.0.0",
      "author": "",
      "manifest": {
        "name": "@public-tauri-ext/google-chrome",
        "icon": "https://www.google.com/chrome/static/images/chrome-logo.svg",
        "title": "Google Chrome",
        "subtitle": "在 Chrome 中打开链接或搜索",
        "description": "触发词 gc + 空格 + 关键词：在 Google Chrome 中打开 Google 搜索；若输入以 http(s):// 开头则直接打开该地址。另支持通过关键词发现「新建 Chrome 窗口」命令。",
        "main": "./dist/index.js",
        "commands": [
          {
            "name": "open",
            "title": "在 Chrome 中打开",
            "subtitle": "触发词 gc，在 Google Chrome 中打开",
            "mode": "none",
            "matches": [
              {
                "type": "regexp",
                "regexp": "^gc\\s+(.+)$",
                "title": "在 Chrome 打开 \"${matches[1]}\"",
                "subtitle": "Google 搜索或打开网址（Google Chrome）"
              },
              {
                "type": "text",
                "keywords": [
                  "google chrome",
                  "chrome",
                  "谷歌浏览器"
                ]
              }
            ]
          },
          {
            "name": "new-window",
            "title": "新建 Chrome 窗口",
            "subtitle": "打开新的 Google Chrome 窗口",
            "mode": "none",
            "matches": [
              {
                "type": "text",
                "keywords": [
                  "chrome new window",
                  "chrome 新窗口",
                  "新建 chrome 窗口",
                  "google chrome new window"
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "name": "@public-tauri-ext/magic",
      "icon": "https://img.icons8.com/?size=100&id=ZXnn88azBI7W&format=png&color=000000",
      "version": "1.0.1",
      "author": "",
      "manifest": {
        "name": "@public-tauri-ext/magic",
        "icon": "https://img.icons8.com/?size=100&id=ZXnn88azBI7W&format=png&color=000000",
        "title": "魔方平台",
        "subtitle": "魔方平台快捷操作",
        "main": "./dist/index.js",
        "commands": [
          {
            "name": "editor",
            "title": "魔方H5编辑页",
            "subtitle": "打开魔方H5编辑页",
            "mode": "none",
            "matches": [
              {
                "type": "text",
                "keywords": [
                  "magic"
                ]
              },
              {
                "type": "trigger",
                "triggers": [
                  "magic",
                  "mact"
                ],
                "title": "打开魔方H5编辑页“$query”"
              },
              {
                "type": "regexp",
                "regexp": "https://.*/magic-act(-beta|-dev)?/([0-9a-zA-Z]+)/",
                "title": "打开魔方H5编辑页“${matches[2]}”"
              }
            ],
            "action": {
              "name": "openUrl",
              "title": "打开页面"
            }
          },
          {
            "name": "mod",
            "title": "魔方模块编辑页",
            "subtitle": "打开魔方模块编辑页",
            "mode": "none",
            "matches": [
              {
                "type": "text",
                "keywords": [
                  "magic"
                ]
              },
              {
                "type": "trigger",
                "triggers": [
                  "magic",
                  "mmod"
                ],
                "title": "打开魔方模块编辑页“$query”"
              }
            ]
          }
        ]
      }
    },
    {
      "name": "@public-tauri-ext/search",
      "icon": "https://img.icons8.com/?size=100&id=63775&format=png&color=000000",
      "version": "1.1.0",
      "author": "",
      "manifest": {
        "name": "@public-tauri-ext/search",
        "icon": "https://img.icons8.com/?size=100&id=63775&format=png&color=000000",
        "title": "网页搜索",
        "subtitle": "触发词 + 关键词，在浏览器中打开搜索结果",
        "description": "输入触发词与空格后的关键词，回车打开对应搜索引擎：g/google/gg→Google，b/bing/必应→必应，bd/baidu/百度→百度。",
        "main": "./dist/index.js",
        "commands": [
          {
            "name": "google",
            "title": "谷歌搜索",
            "subtitle": "在浏览器中打开 Google 搜索结果",
            "mode": "none",
            "matches": [
              {
                "type": "trigger",
                "triggers": [
                  "g",
                  "google",
                  "gg"
                ],
                "title": "谷歌搜索\"$query\"",
                "subtitle": "在浏览器中打开 Google 搜索结果"
              }
            ]
          },
          {
            "name": "bing",
            "title": "必应搜索",
            "subtitle": "在浏览器中打开必应搜索结果",
            "mode": "none",
            "matches": [
              {
                "type": "trigger",
                "triggers": [
                  "b",
                  "bing",
                  "必应"
                ],
                "title": "必应搜索\"$query\"",
                "subtitle": "在浏览器中打开必应搜索结果"
              }
            ]
          },
          {
            "name": "baidu",
            "title": "百度搜索",
            "subtitle": "在浏览器中打开百度搜索结果",
            "mode": "none",
            "matches": [
              {
                "type": "trigger",
                "triggers": [
                  "bd",
                  "baidu",
                  "百度"
                ],
                "title": "百度搜索\"$query\"",
                "subtitle": "在浏览器中打开百度搜索结果"
              }
            ]
          }
        ]
      }
    },
    {
      "name": "@public-tauri-ext/shell",
      "icon": "https://img.icons8.com/?size=100&id=7457&format=png&color=000000",
      "version": "1.0.0",
      "author": "",
      "manifest": {
        "name": "@public-tauri-ext/shell",
        "icon": "https://img.icons8.com/?size=100&id=7457&format=png&color=000000",
        "title": "Shell 命令",
        "subtitle": "用 > 触发并在系统终端中执行命令",
        "description": "输入 > + 空格 + 命令，回车后会拉起 Terminal 并执行该命令。",
        "main": "./dist/index.js",
        "commands": [
          {
            "name": "run",
            "title": "在终端执行命令",
            "subtitle": "触发词 >，回车在 Terminal 执行",
            "mode": "none",
            "matches": [
              {
                "type": "regexp",
                "regexp": "^>\\s*(.+)$",
                "title": "在终端执行 \"${matches[1]}\"",
                "subtitle": "回车后拉起 Terminal 执行命令"
              },
              {
                "type": "text",
                "keywords": [
                  "shell",
                  "terminal",
                  "命令行",
                  "终端"
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "name": "@public-tauri-ext/v2ex",
      "icon": "https://github.com/qwertyyb/public-tauri/blob/master/store/plugins/v2ex/assets/v2ex.png?raw=true",
      "version": "1.0.1",
      "author": "",
      "manifest": {
        "name": "@public-tauri-ext/v2ex",
        "icon": "https://github.com/qwertyyb/public-tauri/blob/master/store/plugins/v2ex/assets/v2ex.png?raw=true",
        "title": "v2ex",
        "subtitle": "查看v2ex热贴和新贴",
        "template": "listView",
        "commands": [
          {
            "name": "hot",
            "title": "v2ex热贴",
            "subtitle": "查看v2ex热贴",
            "mode": "listView",
            "preload": "./dist/command-hot.js"
          },
          {
            "name": "latest",
            "title": "v2ex新贴",
            "subtitle": "查看v2ex新贴",
            "mode": "listView",
            "preload": "./dist/command-latest.js"
          }
        ]
      }
    }
  ]
}