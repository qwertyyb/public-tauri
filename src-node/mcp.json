{
  "mcpServers": {
    "12306": {
      "type": "stdio",
      "disabled": false,
      "command": "npx",
      "args": [
        "-y",
        "12306-mcp"
      ]
    },
    "🔥 Trends Hub": {
      "timeout": 60,
      "command": "npx",
      "args": [
        "-y",
        "mcp-trends-hub@1.6.2"
      ],
      "type": "stdio",
      "disabled": false
    },
    "time": {
      "type": "stdio",
      "disabled": false,
      "command": "uvx",
      "args": [
        "mcp-server-time",
        "--local-timezone=Asia/Shanghai"
      ]
    }
  }
}